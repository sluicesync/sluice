#!/bin/sh
# Pre-commit hook: run formatting check, vet, and fast unit tests
# before allowing a commit. Failures abort the commit with a clear
# message; pass --no-verify to bypass (use sparingly).
#
# Calls gofumpt and go directly so it doesn't depend on `make` being
# installed — works on Windows (Git Bash), macOS, and Linux.
#
# Enable in a fresh clone with:
#   git config core.hooksPath .githooks
#
# See docs/dev/development.md for the full local-dev workflow.

set -e

red()   { printf "\033[31m%s\033[0m\n" "$*"; }
green() { printf "\033[32m%s\033[0m\n" "$*"; }

# ---- Conflict-marker check (applies to ALL files, not just Go) ----
# Catches the case where a cherry-pick / merge / rebase left unresolved
# markers in a file the rest of this hook would skip (the Go-only gate
# below let CHANGELOG.md markers slip through to main on the v0.74.0
# cycle's F5 cherry-pick). Checks `<<<<<<<` and `>>>>>>>` only — those
# are unambiguous; `=======` alone matches legitimate Setext underlines
# in markdown.
markers_files=$(git diff --cached --name-only --diff-filter=ACM | xargs -r grep -lE '^(<<<<<<<|>>>>>>>)' 2>/dev/null || true)
if [ -n "$markers_files" ]; then
	red "pre-commit: unresolved merge-conflict markers in staged files:"
	echo "$markers_files"
	echo ""
	echo "Resolve the conflicts and re-stage before committing."
	exit 1
fi

# Only run Go checks if Go files are staged. Lets non-code commits
# (docs, CI config, etc.) skip the slow steps.
if ! git diff --cached --name-only --diff-filter=ACM | grep -q '\.go$'; then
	green "pre-commit: no Go files staged, skipping checks"
	exit 0
fi

echo "pre-commit: running gofumpt check, go vet, and tests..."

# ---- gofumpt ----
if ! command -v gofumpt >/dev/null 2>&1; then
	red "pre-commit: gofumpt not installed."
	echo "Install: go install mvdan.cc/gofumpt@latest"
	exit 1
fi
# gofumpt walks the FILESYSTEM (unlike go vet's module-scoped ./...), so
# exclude the gitignored .claude/ agent worktrees — live worktree agents
# keep mid-edit files there that are not this tree's problem (same
# reasoning as golangci-lint's .claude/ exclusion, v0.99.236).
unformatted=$(gofumpt -l . | grep -v '^\.claude/' | grep -v '/\.claude/' || true)
if [ -n "$unformatted" ]; then
	red "pre-commit: gofumpt would reformat the following files:"
	echo "$unformatted"
	echo ""
	echo "Run: gofumpt -w ."
	echo "Then: git add ... && git commit"
	exit 1
fi

# ---- go vet ----
if ! go vet ./...; then
	red "pre-commit: go vet failed."
	exit 1
fi

# ---- go vet, per build-tag combination ----
# Bare `go vet ./...` skips every build-tagged file, and `go build
# -tags=...` skips _test.go files — so a symbol rename that a tagged
# test still references passes both and only fails when that suite
# finally runs (the v0.58.1 retag class). vet-tags.sh discovers every
# tag combo in the tree and type-checks each one; results are cached
# by the Go build cache, so repeat runs cost seconds.
if ! sh scripts/vet-tags.sh; then
	red "pre-commit: vet-tags failed (a build-tagged file no longer type-checks)."
	exit 1
fi

# ---- CI coverage guards ----
# These two run in CI's Lint job; without them here, adding
# integration-tagged tests in an uncovered package (or a tagged test
# whose name escapes its job's -run filter) passes the full local gate
# and only fails in CI — contradicting "make pre-commit runs everything
# CI runs". Both are pure git-ls-files/grep, sub-second.
if ! sh scripts/check-shard-coverage.sh; then
	red "pre-commit: check-shard-coverage failed (integration tests outside every CI shard)."
	exit 1
fi
if ! sh scripts/check-run-filter-coverage.sh; then
	red "pre-commit: check-run-filter-coverage failed (a tagged test would never run in any workflow)."
	exit 1
fi

# ---- go test (fast, no DB) ----
# -race is preferred but requires cgo. On Windows / minimal-toolchain
# setups CGO_ENABLED=0 by default, in which case we skip -race locally
# and rely on CI (Linux runners, cgo on) to catch races. Same checks
# either way, just a slightly slimmer guarantee on Windows.
test_args="-count=1"
if [ "$(go env CGO_ENABLED 2>/dev/null)" = "1" ]; then
	test_args="$test_args -race"
fi
if ! go test $test_args ./... >/dev/null; then
	red "pre-commit: tests failed."
	echo "Run: go test ./...  (to see the failure)"
	exit 1
fi

# ---- golangci-lint (mirrors CI's Lint job) ----
# Pre-v0.39.1 this gate was missing — gofumpt + go vet caught
# formatting + obvious-bug issues but unused-symbol / revive / etc.
# only ran in CI, which meant lint-only failures slipped through the
# local pre-commit gate for several releases. Adding it here matches
# the CI job exactly.
#
# Soft-skip when golangci-lint isn't installed (developer convenience)
# rather than hard-block — CI is the source of truth.
if command -v golangci-lint >/dev/null 2>&1; then
	if ! golangci-lint run; then
		# A stale analysis cache reports PHANTOM issues after a sibling
		# git worktree is removed (typecheck/unused findings pointing at
		# files that no longer exist — hit 4x with the worktree-agent
		# flow). Self-heal: clean the cache and retry ONCE. A cold-cache
		# run costs minutes, so this only happens on failure — real
		# findings reproduce identically on the retry.
		echo "pre-commit: golangci-lint failed; retrying once with a clean cache (stale-worktree phantom check)..."
		golangci-lint cache clean
		if ! golangci-lint run; then
			red "pre-commit: golangci-lint failed."
			echo "Run: golangci-lint run  (to see the failures inline)"
			exit 1
		fi
	fi
else
	echo "pre-commit: golangci-lint not installed; skipping (install: https://golangci-lint.run/welcome/install/)"
fi

green "pre-commit: OK"
