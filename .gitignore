# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/dist/
/build/

# Test artifacts
*.test
*.out
coverage.txt
coverage.html
profile.out

# Exception: vendored sqllogictest corpus files under testdata are
# upstream fixtures we need to track, not Go test binaries. See
# internal/translate/testdata/sqllogictest/NOTICE for provenance.
!**/testdata/**/*.test

# Go workspace files
go.work
go.work.sum

# Module dependency directories
vendor/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Claude Code local state
.claude/

# Environment and secrets
.env
.env.local
*.env
*.pem
*.key

# Local developer config
config.local.yaml
config.local.yml

# Machine-local Claude Code operator/automation runbook (never committed)
CLAUDE.local.md

# The Hyper-V self-hosted-runner provisioning kit moved to the private
# sluicesync/sluice-ops repo. This guards a maintainer's leftover local
# VHDX cache (scripts/hyperv-runner/.work/, ~90 GB) from ever being
# accidentally staged here. Fresh clones won't have this directory.
scripts/hyperv-runner/

# Generated test fixtures and large datasets
test/perf/data/
test/integration/dumps/

# Generative fuzz harness — dumped failing fixtures (replayable from
# the printed seed; promote to a permanent named pin by hand, don't
# commit the raw dump dir).
internal/pipeline/testdata/fuzz-failures/

# Real-world schema corpus (Idea 3, prep-new-test-surfaces.md): fetched
# upstream DDL is large + upstream-owned — fetch-on-demand, do not
# vendor the dumps. The committed MANIFEST.md (provenance: source /
# license / upstream commit) and fetch script ARE tracked (exceptions
# below).
internal/pipeline/testdata/real-world-corpus/*
!internal/pipeline/testdata/real-world-corpus/MANIFEST.md
!internal/pipeline/testdata/real-world-corpus/fetch.sh

# Logs
*.log
